       <property name="text"><string>Scan</string></property>
       <property name="minimumWidth"><number>90</number></property>
      </widget>
     </item>
    </layout>
   </item>

   <!-- Progress bar -->
   <item>
    <widget class="QProgressBar" name="progressBar">
     <property name="minimum"><number>0</number></property>
     <property name="maximum"><number>1</number></property>
     <property name="value"><number>0</number></property>
     <property name="textVisible"><bool>false</bool></property>
     <property name="maximumHeight"><number>6</number></property>
    </widget>
   </item>

   <!-- Splitter: Trainers (left) | HRM (right) -->
   <item>
    <widget class="QSplitter" name="splitter">
     <property name="orientation"><enum>Qt::Horizontal</enum></property>

     <!-- Trainer group -->
     <widget class="QGroupBox" name="grpTrainer">
      <property name="title"><string>Bike Trainer</string></property>
